generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id                String   @id @default(uuid())
  name              String   @unique
  league            String
  country_code      String
  city              String
  stadium           String
  biggest_rival     String?
  other_rivals      String?
  policing_conflict String?
  sheet_source      String
  // UCL-specific fields
  uefa_pot          String?
  home_advantage    Float?
  geographic_zone   String?
  winter_restricted Boolean  @default(false)
  // Legacy fields for backward compat
  group_id          String   @default("X")
  is_seeded         Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([league])
  @@index([sheet_source])
  @@index([is_seeded])
}

model Player {
  id                        String   @id
  name                      String
  club                      String
  position                  String
  cost_millions             Float
  overall_ability           Int
  expectation_status        String
  expectation_multiplier    Float
  base_form                 Float
  home_stadium_multiplier   Float
  last_3_vs_opponent_pts    Float
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
}
