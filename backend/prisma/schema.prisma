generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Team {
  id           String   @id @default(uuid()) @db.VarChar(36)
  name         String   @unique @db.VarChar(100)
  country_code String   @db.VarChar(3)
  group_id     String   @db.Char(1)
  is_seeded    Boolean
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([is_seeded])
  @@map("teams")
}

model Player {
  id            String   @id @default(uuid()) @db.VarChar(36)
  name          String   @db.VarChar(100)
  club_name     String   @db.VarChar(50)
  position      Position
  cost_millions Decimal  @db.Decimal(4, 1)
  points        Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([position])
  @@index([club_name])
  @@map("players")
}

enum Position {
  GK
  DEF
  MID
  FWD
}
